pipeline {
    agent any

    environment {
        APP_DIR        = 'lab3-reatiltech-app'
        IMAGE_NAME     = 'retailtech/product-service'
        LOCAL_REGISTRY = 'localhost:5000'
        IMAGE_TAG      = "${env.BUILD_NUMBER}-${env.GIT_COMMIT ? env.GIT_COMMIT.take(7) : 'local'}"
        COMPOSE_NET    = 'project-dev-ops_devops-network'
    }

    options {
        buildDiscarder(logRotator(numToKeepStr: '10'))
        timeout(time: 15, unit: 'MINUTES')
        disableConcurrentBuilds()
        timestamps()
    }

    stages {

        // ──────────────────────────────────────────
        stage('Checkout') {
        // ──────────────────────────────────────────
            steps {
                script {
                    echo '🔍 Clonando repositorio...'
                    checkout scm
                    env.GIT_COMMIT_MSG = sh(
                        script: 'git log -1 --pretty=%B',
                        returnStdout: true
                    ).trim()
                    echo "📝 Commit: ${env.GIT_COMMIT_MSG}"
                    echo "🔖 Tag de imagen: ${IMAGE_TAG}"
                }
            }
        }

        // ──────────────────────────────────────────
        stage('Install & Test') {
        // ──────────────────────────────────────────
            steps {
                echo '🧪 Ejecutando tests...'
                dir("${APP_DIR}") {
                    sh 'npm install'
                    sh 'npm test || true'
                }
            }
            post {
                always {
                    echo '📊 Tests finalizados'
                }
            }
        }

        // ──────────────────────────────────────────
        stage('SonarQube Analysis') {
        // ──────────────────────────────────────────
            steps {
                echo '🔍 Analizando calidad del código...'
                script {
                    try {
                        withSonarQubeEnv('SonarQube') {
                            dir("${APP_DIR}") {
                                sh """
                                    docker run --rm \
                                        --network ${COMPOSE_NET} \
                                        -v "\$(pwd)":/usr/src \
                                        -e SONAR_HOST_URL=\${SONAR_HOST_URL} \
                                        -e SONAR_TOKEN=\${SONAR_AUTH_TOKEN} \
                                        sonarsource/sonar-scanner-cli:latest \
                                        -Dsonar.projectKey=retailtech-product-service \
                                        -Dsonar.projectName='RetailTech Product Service' \
                                        -Dsonar.sources=/usr/src \
                                        -Dsonar.exclusions='**/node_modules/**,**/coverage/**'
                                """
                            }
                        }
                    } catch(e) {
                        echo "⚠️ SonarQube analysis omitido: ${e.message}"
                        echo '💡 Configura el token en http://localhost:9000 y actualiza la credencial sonarqube-token en Jenkins'
                    }
                }
            }
        }

        // ──────────────────────────────────────────
        stage('Build Docker Image') {
        // ──────────────────────────────────────────
            steps {
                echo '🐳 Construyendo imagen Docker...'
                sh """
                    docker build \
                        -t ${LOCAL_REGISTRY}/${IMAGE_NAME}:${IMAGE_TAG} \
                        -t ${LOCAL_REGISTRY}/${IMAGE_NAME}:latest \
                        --label "build.number=${env.BUILD_NUMBER}" \
                        --label "git.commit=${env.GIT_COMMIT}" \
                        ${APP_DIR}/
                """
                echo "✅ Imagen: ${IMAGE_NAME}:${IMAGE_TAG}"
            }
        }

        // ──────────────────────────────────────────
        stage('Push to Local Registry') {
        // ──────────────────────────────────────────
            steps {
                echo '📤 Publicando al registry local (localhost:5000)...'
                sh "docker push ${LOCAL_REGISTRY}/${IMAGE_NAME}:${IMAGE_TAG}"
                sh "docker push ${LOCAL_REGISTRY}/${IMAGE_NAME}:latest"
                echo '✅ Imagen publicada'
            }
        }

        // ──────────────────────────────────────────
        stage('Deploy') {
        // ──────────────────────────────────────────
            steps {
                echo '🚀 Desplegando nueva versión del product-service...'
                sh """
                    docker stop retailtech-product-service || true
                    docker rm   retailtech-product-service || true
                    docker run -d \
                        --name retailtech-product-service \
                        --network ${COMPOSE_NET} \
                        -p 3000:3000 \
                        -e NODE_ENV=production \
                        -e PORT=3000 \
                        ${LOCAL_REGISTRY}/${IMAGE_NAME}:${IMAGE_TAG}
                """
                echo '✅ Deployment completado'
            }
        }

        // ──────────────────────────────────────────
        stage('Smoke Tests') {
        // ──────────────────────────────────────────
            steps {
                echo '💨 Smoke tests...'
                sh '''
                    # Esperar a que el servicio arranque (retry)
                    for i in $(seq 1 10); do
                        response=$(curl -s http://retailtech-product-service:3000/health 2>/dev/null)
                        if echo "$response" | grep -q "UP"; then
                            echo "✅ Health check OK (intento $i): $response"
                            break
                        fi
                        echo "Intento $i: servicio no listo, reintentando..."
                        sleep 3
                        [ $i -eq 10 ] && echo "❌ Health check FALLÓ tras 10 intentos" && exit 1
                    done

                    # Test API products
                    response=$(curl -s http://retailtech-product-service:3000/api/products)
                    if echo "$response" | grep -q "id"; then
                        echo "✅ API products OK"
                    else
                        echo "❌ API products FALLÓ: $response"
                        exit 1
                    fi
                '''
            }
        }
    }

    post {
        success {
            echo '🎉 Pipeline completado exitosamente!'
            echo '🔗 Product Service: http://localhost:3000'
            echo '📖 Swagger UI:      http://localhost:3000/docs'
            echo '📊 Métricas:        http://localhost:9090'
            echo '📈 Grafana:         http://localhost:3001'
        }
        failure {
            echo '❌ Pipeline falló — revisa los logs arriba'
        }
        always {
            cleanWs()
            sh 'docker image prune -f || true'
        }
    }
}
